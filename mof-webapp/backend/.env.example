# Database
DATABASE_URL=postgresql+asyncpg://mof:mof@postgres:5432/mof

# Security
SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys - Plaid (US)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox  # sandbox, development, production

# API Keys - GoCardless (UK)
GOCARDLESS_ACCESS_TOKEN=your_gocardless_token
GOCARDLESS_ENV=sandbox  # sandbox, live

# API Keys - Interactive Brokers
IBKR_ACCOUNT_ID=your_ibkr_account
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# API Keys - Trading 212
TRADING212_API_KEY=your_trading212_key
TRADING212_ENV=demo  # demo, live

# Sync Schedule (cron format)
SYNC_SCHEDULE=0 */6 * * *  # Every 6 hours

# Server
HOST=0.0.0.0
PORT=8000
